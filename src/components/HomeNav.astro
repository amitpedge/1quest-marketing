---
const navByExam = {
  school: [
    { href: "/#agents", label: "Agents" },
    { href: "/#how", label: "How it works" },
    { href: "/#parents", label: "For parents" },
    { href: "/#trust", label: "Why 1Quest" },
    { href: "/school/", label: "Guides" },
    { href: "/about/", label: "About" },
  ],
  upsc: [
    { href: "/#upsc-how", label: "Agents" },
    { href: "/#upsc-how", label: "Prelims & mains" },
    { href: "/#download", label: "Get the app" },
    { href: "/about/", label: "About" },
  ],
};

const exams = [
  { id: "school", label: "School", short: "Sch", active: true },
  { id: "jee", label: "JEE", short: "JEE", active: false },
  { id: "neet", label: "NEET", short: "NEET", active: false },
  { id: "upsc", label: "UPSC", short: "UPSC", active: true },
];
---

<header class="nav">
  <div class="nav__shell">
    <a class="brand" href="/" aria-label="1Quest home">
      <img class="brand__img" src="/1quest-logo.svg" alt="1Quest" width="2165" height="1237" />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {
        Object.entries(navByExam).map(([exam, links]) => (
          <div class={`nav-set mode-${exam}`} data-nav-set={exam}>
            {links.map(({ href, label }) => (
              <a href={href}>{label}</a>
            ))}
          </div>
        ))
      }
    </nav>

    <div class="nav__right">
      <div class="exam-bar" role="group" aria-label="Choose your exam">
        <span class="exam-bar__k">Exam</span>
        <div class="exam-bar__options">
          {
            exams.map(({ id, label, short, active }) =>
              active ? (
                <button
                  type="button"
                  class="exam-bar__opt"
                  data-mode-btn={id}
                  aria-pressed={id === "school" ? "true" : "false"}
                >
                  <span class="exam-bar__long">{label}</span>
                  <span class="exam-bar__short">{short}</span>
                </button>
              ) : (
                <button
                  type="button"
                  class="exam-bar__opt exam-bar__opt--soon"
                  disabled
                  aria-disabled="true"
                  title="Coming soon"
                >
                  <span class="exam-bar__long">{label}</span>
                  <span class="exam-bar__short">{short}</span>
                  <span class="exam-bar__badge">Soon</span>
                </button>
              )
            )
          }
        </div>
      </div>
      <a class="nav__login" href="https://app.1quest.app/">Sign in</a>
    </div>
  </div>
</header>
