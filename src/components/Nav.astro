---
const links = [
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
  { href: "/privacy/", label: "Privacy" },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <a class="brand" href="/">
    <span class="mark" aria-hidden="true">1Q</span>
    <span class="brand-text">
      <span class="name">1Quest</span>
      <span class="tag">Learn</span>
    </span>
  </a>
  <div class="links">
    {
      links.map(({ href, label }) => (
        <a class:list={["link", currentPath === href && "active"]} href={href}>
          {label}
        </a>
      ))
    }
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text);
    text-decoration: none;
  }

  .brand:hover {
    text-decoration: none;
    color: var(--text);
  }

  .mark {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.85rem;
    background: linear-gradient(135deg, #c2410c, #0f766e);
    color: #fff7ed;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: -0.04em;
    box-shadow: 0 10px 24px rgba(180, 83, 9, 0.18);
  }

  .brand-text {
    display: flex;
    align-items: baseline;
    gap: 0.45rem;
  }

  .name {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
  }

  .tag {
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    padding: 0.25rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--border);
  }

  .link {
    padding: 0.45rem 0.85rem;
    border-radius: 999px;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 600;
    text-decoration: none;
  }

  .link:hover,
  .link.active {
    background: rgba(255, 255, 255, 0.92);
    color: var(--text);
    text-decoration: none;
  }
</style>
