---
const links = [
  { href: "/about/", label: "About" },
  { href: "/contact/", label: "Contact" },
  { href: "/privacy/", label: "Privacy" },
];

const currentPath = Astro.url.pathname;
---

<nav class="nav">
  <a class="brand" href="/">
    <span class="name">1Quest</span>
    <span class="tag">Learn</span>
  </a>
  <div class="links">
    {
      links.map(({ href, label }) => (
        <a class:list={["link", currentPath === href && "active"]} href={href}>
          {label}
        </a>
      ))
    }
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    color: var(--text);
    text-decoration: none;
    font-weight: 700;
    font-size: 1.125rem;
  }

  .brand:hover {
    text-decoration: none;
    color: var(--text);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .link {
    color: var(--muted);
    font-size: 0.95rem;
    text-decoration: none;
  }

  .link:hover,
  .link.active {
    color: var(--text);
    text-decoration: none;
  }
</style>
