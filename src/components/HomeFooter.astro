---
const year = new Date().getFullYear();

const columns = [
  {
    title: "Product",
    links: [
      { label: "How it works", href: "/#how" },
      { label: "For parents", href: "/#parents" },
      { label: "School guides", href: "/school/" },
      { label: "The agents", href: "/#agents" },
    ],
  },
  {
    title: "Company",
    links: [
      { label: "About", href: "/about/" },
      { label: "Contact", href: "/contact/" },
    ],
  },
  {
    title: "Exams",
    links: [
      { label: "School", href: "/?exam=school" },
      { label: "UPSC", href: "/?exam=upsc" },
      { label: "JEE", soon: true },
      { label: "NEET", soon: true },
    ],
  },
  {
    title: "Legal",
    links: [{ label: "Privacy", href: "/privacy/" }],
  },
];
---

<footer class="foot">
  <div class="foot__shell">
    <div class="foot__top">
      <a class="brand" href="/" aria-label="1Quest home">
        <img class="brand__img" src="/1quest-logo.svg" alt="1Quest" width="2165" height="1237" />
      </a>
      <p class="foot__tag">AI study agents for school and UPSC. JEE &amp; NEET coming soon.</p>
    </div>

    <div class="foot__grid">
      {
        columns.map((col) => (
          <div class="foot__col">
            <h3>{col.title}</h3>
            <ul>
              {col.links.map((link) => (
                <li>
                  {"soon" in link && link.soon ? (
                    <span class="foot__soon">
                      {link.label} <span class="foot__soon-k">· coming soon</span>
                    </span>
                  ) : (
                    <a href={link.href}>{link.label}</a>
                  )}
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <p class="foot__copy">© {year} 1Quest. All rights reserved.</p>
  </div>
</footer>
