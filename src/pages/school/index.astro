---
import HomeLayout from "../../layouts/HomeLayout.astro";
import "../../styles/content.css";

const guides = [
  {
    href: "/school/cbse-hots-explained/",
    k: "Guide",
    title: "CBSE HOTS explained for parents",
    body: "What Higher Order Thinking Skills mean in CBSE exams, what changed in 2026–27, and how to help your child prepare without doing it for them.",
  },
  {
    href: "/school/cbse-case-based-questions/",
    k: "Guide",
    title: "CBSE case-based questions — a parent decoder",
    body: "How to read case-based and source-based questions in Science, Maths, and Social Science — with examples, marking logic, and weekly practice tips.",
  },
  {
    href: "/school/extracurricular-assignments/",
    k: "Guide",
    title: "Model UN, essays, debates & demonstrations",
    body: "How to help your child prepare for the endless variety of school assignments — patiently, and without doing it for them.",
  },
  {
    href: "/school/patient-ai-tutor/",
    k: "Guide",
    title: "How AI can patiently teach your child",
    body: "What patience really means in learning — and how an AI tutor that never sighs, rushes, or gives up changes how your child understands things.",
  },
  {
    href: "/school/weekly-learning-plan/",
    k: "Guide",
    title: "Lock a plan with the parent, execute it with the child",
    body: "How 1Quest agrees a week's plan with you in minutes, then patiently runs it with your child day by day — and reports back.",
  },
];

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://1quest.app/" },
    {
      "@type": "ListItem",
      position: 2,
      name: "School guides",
      item: "https://1quest.app/school/",
    },
  ],
};
---

<HomeLayout
  title="1Quest for School — guides for parents"
  description="Practical, honest guides for parents on helping your child learn: from the endless variety of school assignments to the skills that last."
  jsonLd={breadcrumb}
>
  <section class="article__header">
    <div class="wrap-read">
      <p class="eyebrow">1Quest for School</p>
      <h1 class="article__title">Guides for parents</h1>
      <p class="article__lead">
        Practical, honest guides on helping your child learn — from the endless variety of
        school assignments to the skills that stay for life.
      </p>
    </div>
  </section>

  <section class="shell guides">
    <div class="guidegrid">
      {
        guides.map((g) => (
          <a class="guidecard" href={g.href}>
            <span class="guidecard__k">{g.k}</span>
            <h3>{g.title}</h3>
            <p>{g.body}</p>
          </a>
        ))
      }
    </div>
    <p class="guides-more">
      More guides — handwriting, essay writing, writing to a word limit, and structuring
      answers — are on the way.
    </p>
  </section>
</HomeLayout>
