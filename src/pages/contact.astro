---
import HomeLayout from "../layouts/HomeLayout.astro";
import "../styles/content.css";
---

<HomeLayout
  title="Contact — 1Quest"
  description="Reach the 1Quest team with questions, feedback, or partnership ideas."
>
  <article class="inner">
    <header class="inner__header wrap-read">
      <p class="eyebrow">Contact</p>
      <h1 class="inner__title">Get in <em>touch</em></h1>
      <p class="inner__lead">Questions, feedback, or ideas — we'd like to hear from you.</p>
    </header>

    <div class="wrap-read inner__body prose-lg">
      <h2>Product support</h2>
      <p>
        For account issues or in-app help, use the help centre once you're signed in to 1Quest.
        That gets you to the right team fastest.
      </p>

      <h2>Everything else</h2>
      <p>For this marketing site — partnerships, press, or general questions — email us:</p>
      <a class="inner__contact" href="mailto:hello@1quest.app">hello@1quest.app</a>
      <p class="inner__note">
        <em>We read every message. Response times vary, but we typically reply within a few business days.</em>
      </p>
    </div>
  </article>
</HomeLayout>
