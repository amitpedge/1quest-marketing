---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Contact — 1Quest Learn"
  description="Reach the 1Quest team with questions, feedback, or partnership ideas."
>
  <section class="page-hero">
    <p class="eyebrow">Contact</p>
    <h1 class="page-title">Get in <span class="grad">touch</span></h1>
    <p class="lede">Questions, feedback, or ideas — we'd like to hear from you.</p>
  </section>

  <div class="prose">
    <p>
      For product support and account issues, use the in-app help once you're signed in to 1Quest.
      For everything else on this marketing site, email us:
    </p>
    <p>
      <a href="mailto:hello@1quest.app">hello@1quest.app</a>
    </p>
    <p>
      We read every message. Response times vary, but we typically reply within a few business days.
    </p>
  </div>
</Layout>
