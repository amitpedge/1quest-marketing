---
import HomeLayout from "../../layouts/HomeLayout.astro";
import "../../styles/content.css";
---

<HomeLayout
  title="1Quest NEET — coming soon"
  description="AI study agents for NEET preparation are on the way from 1Quest."
  exam="neet"
>
  <article class="inner">
    <header class="inner__header wrap-read">
      <p class="eyebrow">NEET</p>
      <h1 class="inner__title">NEET prep agents are <em>coming soon</em></h1>
      <p class="inner__lead">
        We're building the same patient, step-by-step teaching for NEET — syllabus mapping,
        drills, and honest review. Join the waitlist and we'll let you know when it launches.
      </p>
    </header>
    <div class="wrap-read inner__body prose-lg">
      <p>
        <a class="btn btn--solid" href="/contact/">Get in touch</a>
      </p>
      <p>
        In the meantime, explore <a href="/">School</a> or <a href="/upsc/">UPSC</a> on 1Quest.
      </p>
    </div>
  </article>
</HomeLayout>
