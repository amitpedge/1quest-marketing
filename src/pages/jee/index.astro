---
import HomeLayout from "../../layouts/HomeLayout.astro";
import "../../styles/content.css";
---

<HomeLayout
  title="1Quest JEE — coming soon"
  description="AI study agents for JEE preparation are on the way from 1Quest."
  exam="jee"
>
  <article class="inner">
    <header class="inner__header wrap-read">
      <p class="eyebrow">JEE</p>
      <h1 class="inner__title">JEE prep agents are <em>coming soon</em></h1>
      <p class="inner__lead">
        We're building the same patient, step-by-step teaching for JEE — syllabus mapping,
        problem drills, and honest review. Join the waitlist and we'll let you know when it
        launches.
      </p>
    </header>
    <div class="wrap-read inner__body prose-lg">
      <p>
        <a class="btn btn--solid" href="/contact/">Get in touch</a>
      </p>
      <p>
        In the meantime, explore <a href="/">School</a> or <a href="/upsc/">UPSC</a> on 1Quest.
      </p>
    </div>
  </article>
</HomeLayout>
