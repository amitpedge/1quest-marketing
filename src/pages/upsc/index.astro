---
import HomeLayout from "../../layouts/HomeLayout.astro";

const productApp = "https://upsc.1quest.app";

const products = [
  {
    k: "Editorial",
    name: "Editorial X-Ray",
    body: "Complex editorials explained step by step — Pre-Read, Teach Me in English or Hinglish, and GS paper mapping.",
    href: `${productApp}/editorial`,
    cta: "Try Editorial X-Ray →",
  },
  {
    k: "Mains",
    name: "Answer Co-Write",
    body: "Build your Mains blueprint before you write — topic by topic, argument by argument.",
    href: `${productApp}/cowrite`,
    cta: "Try Answer Co-Write →",
  },
  {
    k: "Concepts",
    name: "1Q Concepts",
    body: "Unblock complex topics with concept notes tuned for Prelims and Mains — from one query.",
    href: `${productApp}/concepts`,
    cta: "Try 1Q Concepts →",
  },
  {
    k: "Evaluation",
    name: "Answer Evaluation",
    body: "AI that reads your handwriting, checks facts, and grades against UPSC marking criteria.",
    href: `${productApp}/evaluation`,
    cta: "Try Answer Evaluation →",
  },
  {
    k: "Notes",
    name: "Notes Vault",
    body: "Your topic-wise knowledge base — notes, breakdowns, and elaborations retrievable in seconds.",
    href: `${productApp}/vault`,
    cta: "Open Notes Vault →",
  },
  {
    k: "Current affairs",
    name: "Budget & Economic Survey",
    body: "Union Budget 2026-27 and Economic Survey chapters decoded for Prelims and Mains.",
    href: `${productApp}/budget-2026-27`,
    cta: "Read Budget analysis →",
  },
];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "1Quest UPSC",
  url: "https://1quest.app/upsc/",
  description: "1Quest builds AI study agents for UPSC aspirants.",
};
---

<HomeLayout
  title="1Quest UPSC — a patient mentor for every aspirant"
  description="1Quest gives UPSC aspirants an always-on agent that maps the syllabus, drills prelims, and reviews mains answers — in your language, at your pace."
  jsonLd={websiteSchema}
  exam="upsc"
>
  <section class="hero">
    <div class="hero__shell">
      <div class="hero__lede">
        <p class="eyebrow">AI study agents · UPSC</p>
        <h1 class="display">A <em>patient</em> mentor for every UPSC aspirant.</h1>
        <p class="sub">
          1Quest gives you an always-on agent that maps the syllabus, drills prelims,
          and reviews your answers — in your language, at your pace.
        </p>

        <div class="hero__cta">
          <a class="btn btn--solid" href="/contact/">Start free</a>
          <a class="btn btn--ghost" href="#how">See how it works</a>
        </div>

        <p class="agents">
          <span class="agents__label">Live on the web app</span>
          Editorial X-Ray · Co-Write · Concepts · Evaluation
        </p>
      </div>

      <div class="hero__art" aria-hidden="true">
        <div class="chatcard">
          <div class="chatcard__head">
            <span class="chatcard__eyebrow">1Quest agent</span>
            <span class="chatcard__name">Prelims Coach</span>
          </div>
          <div class="chatcard__body">
            <p class="bubble bubble--in">Explain the Doctrine of Lapse in two lines.</p>
            <p class="bubble bubble--out">
              Annexation policy under Dalhousie: if a ruler died without a natural heir,
              the state lapsed to the Company. It fuelled resentment before 1857.
            </p>
          </div>
          <div class="chatcard__foot">
            <span class="pulse"></span> Always on · answers at your pace
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="appcta" id="download">
    <div class="shell appcta__inner">
      <img class="appcta__icon" src="/1quest-monogram.svg" alt="1Quest app icon" width="940" height="865" />
      <div class="appcta__text">
        <h2 class="appcta__title">Download the app — right away.</h2>
        <p class="appcta__sub">Get 1Quest on the App Store and Play Store, and start today.</p>
      </div>
      <div class="appcta__badges">
        <a class="appcta__badge" href="/contact/" aria-label="Download on the App Store">
          <img src="/appstore-badge.svg" alt="Download on the App Store" width="168" height="50" />
        </a>
        <a class="appcta__badge" href="/contact/" aria-label="Get it on Google Play">
          <img src="/googleplay-badge.svg" alt="Get it on Google Play" width="180" height="50" />
        </a>
      </div>
    </div>
  </section>

  <section class="upsc-brief" id="how">
    <div class="shell">
      <div class="section-head">
        <p class="eyebrow eyebrow--center">For UPSC aspirants</p>
        <h2 class="display-sm">A disciplined mentor for the long haul.</h2>
        <p class="lead center">
          1Quest plans your prep, drills prelims daily, and reviews mains answers with the
          honesty a rank demands. Try the live tools below.
        </p>
      </div>

      <div class="agentgrid agentgrid--upsc" id="agents">
        {
          products.map((product) => (
            <article class="agent">
              <span class="agent__k">{product.k}</span>
              <h3 class="agent__name">{product.name}</h3>
              <p>{product.body}</p>
              <a class="agent__link" href={product.href}>
                {product.cta}
              </a>
            </article>
          ))
        }

        <article class="agent agent--wide agent--wide-upsc">
          <span class="agent__k">All tools</span>
          <h3 class="agent__name">Open the full UPSC web app</h3>
          <p>
            Editorial analysis, answer co-writing, concept notes, evaluation, vault, and
            Budget &amp; Economic Survey guides — all live at upsc.1quest.app.
          </p>
          <a class="agent__link" href={productApp}>
            Go to upsc.1quest.app →
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="quote">
    <div class="shell quote__shell">
      <blockquote class="quote__text">
        “I stopped drowning in PDFs. My agent knew where I'd left off, what I kept getting
        wrong, and what to revise next. It felt like studying with someone.”
      </blockquote>
      <p class="quote__cite">Priya Sharma · UPSC aspirant, Jaipur</p>
    </div>
  </section>

  <section class="closing">
    <div class="shell closing__inner">
      <h2 class="closing__title">Bring a disciplined mentor to your prep desk.</h2>
      <p class="closing__sub">
        Free to start. Map the syllabus, drill daily, and get honest answer reviews.
      </p>
      <a class="btn btn--solid" href="/contact/">Start free</a>
    </div>
  </section>
</HomeLayout>
