---
import "../styles/tokens.css";
import "../styles/home.css";
import HomeNav from "../components/HomeNav.astro";
import HomeFooter from "../components/HomeFooter.astro";
import { examFromPathname, resolveExam, type ExamId } from "../lib/exam";

interface Props {
  title: string;
  description?: string;
  image?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  exam?: ExamId;
}

const {
  title,
  description = "1Quest builds AI study agents for school students and UPSC aspirants.",
  image = "/og-image.png",
  jsonLd,
  exam: examProp,
} = Astro.props;

const pathExam = examFromPathname(Astro.url.pathname);
const agnostic = pathExam === "agnostic";
const exam = resolveExam(Astro.url.pathname, examProp ?? pathExam);

const canonical = new URL(Astro.url.pathname, Astro.site);
const origin = (Astro.site?.toString() ?? "https://1quest.app/").replace(/\/$/, "");
const ogImage = origin + image;

const organization = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "1Quest",
  url: origin + "/",
  logo: origin + "/logo-512.png",
  description: "1Quest builds AI study agents for school students and UPSC aspirants.",
};

const extraSchemas = Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : [];
const schemas = [organization, ...extraSchemas];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/1quest-monogram.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&display=swap"
      rel="stylesheet"
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="1Quest" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="1Quest — AI study agents for school and UPSC" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImage} />
    {
      schemas.map((schema) => (
        <script type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }
  </head>
  <body>
    <div
      class="home"
      data-exam={exam}
      data-agnostic={agnostic ? "true" : undefined}
    >
      <HomeNav exam={exam} agnostic={agnostic} />
      <main>
        <slot />
      </main>
      <HomeFooter />
    </div>

    <script is:inline define:vars={{ agnostic }}>
      (() => {
        const root = document.querySelector(".home");
        if (!root) return;

        const valid = new Set(["school", "upsc", "jee", "neet"]);

        const examFromPath = () => {
          const p = location.pathname;
          if (p.startsWith("/upsc")) return "upsc";
          if (p.startsWith("/jee")) return "jee";
          if (p.startsWith("/neet")) return "neet";
          if (p.startsWith("/school") || p === "/" || p === "") return "school";
          return null;
        };

        const applyExam = (exam) => {
          if (!valid.has(exam)) exam = "school";
          root.setAttribute("data-exam", exam);

          document.querySelectorAll("[data-exam-tab]").forEach((tab) => {
            const active = tab.dataset.examTab === exam;
            tab.classList.toggle("exam-tabs__tab--active", active);
            tab.setAttribute("aria-current", active ? "page" : "false");
          });
        };

        let exam = examFromPath();
        if (!exam && agnostic) {
          try {
            exam = localStorage.getItem("1q-exam");
          } catch (e) {}
        }
        if (!exam || !valid.has(exam)) exam = root.getAttribute("data-exam") || "school";
        applyExam(exam);

        document.querySelectorAll("[data-exam-tab]").forEach((link) => {
          link.addEventListener("click", () => {
            try {
              localStorage.setItem("1q-exam", link.dataset.examTab);
            } catch (e) {}
          });
        });

        const drawer = document.querySelector("[data-menu-drawer]");
        const backdrop = document.querySelector("[data-menu-backdrop]");
        const openBtn = document.querySelector("[data-menu-btn]");
        const closeBtn = document.querySelector("[data-menu-close]");

        const setMenuOpen = (open) => {
          if (!drawer || !backdrop || !openBtn) return;
          drawer.classList.toggle("is-open", open);
          backdrop.classList.toggle("is-open", open);
          drawer.setAttribute("aria-hidden", String(!open));
          backdrop.hidden = !open;
          openBtn.setAttribute("aria-expanded", String(open));
          document.body.classList.toggle("menu-open", open);
        };

        openBtn?.addEventListener("click", () => setMenuOpen(true));
        closeBtn?.addEventListener("click", () => setMenuOpen(false));
        backdrop?.addEventListener("click", () => setMenuOpen(false));

        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") setMenuOpen(false);
        });
      })();
    </script>
  </body>
</html>
